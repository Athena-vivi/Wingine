{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "core/**/*.ts",
    "usecases/**/*.ts",
    "api/**/*.ts",
    "demos/**/*.ts"
  ]
}
