{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": false,
    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "skipLibCheck": true,
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "global.d.ts",
    "api/**/*.ts",
    "src/modules/system/problem/**/*.ts",
    "src/modules/system/builder/build.ts",
    "src/modules/system/builder/contentDraftGenerator.ts",
    "src/modules/system/builder/ioContractBuilder.ts",
    "src/modules/system/builder/structuralModulePlanner.ts",
    "src/modules/system/builder/systemSpecBuilder.ts",
    "src/modules/system/builder/content/**/*.ts",
    "src/modules/capability/runtime/**/*.ts",
    "src/modules/capability/decision/types.ts",
    "src/modules/capability/decision/problemDecision.ts",
    "src/modules/capability/decision/scoring/**/*.ts",
    "src/modules/capability/decision/betting/**/*.ts",
    "src/modules/capability/execution/**/*.ts",
    "src/modules/capability/feedback/**/*.ts",
    "src/modules/capability/shared/**/*.ts",
    "src/contracts/**/*.ts",
    "src/control/**/*.ts",
    "src/execution/**/*.ts",
    "src/protocols/**/*.ts",
    "src/system-builder/**/*.ts",
    "src/system-builder/**/*.tsx",
    "src/workflows/**/*.ts",
    "usecases/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
